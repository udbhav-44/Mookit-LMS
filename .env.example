# ── Database ──────────────────────────────────────────────────────────────────
DB__URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mookit_lms
DB__POOL_SIZE=20
DB__MAX_OVERFLOW=10

# ── Redis ─────────────────────────────────────────────────────────────────────
# MUST be set in production; use a long random value.
REDIS_PASSWORD=change-me-redis-password
REDIS__URL=redis://:${REDIS_PASSWORD}@localhost:6379/0

# API/UI bind. Keep localhost unless reverse-proxied intentionally.
API_PORT_BIND=127.0.0.1:8000
# pgAdmin is opt-in (`docker compose --profile ops ...`) and local-only by default.
PGADMIN_PORT_BIND=127.0.0.1:5050

# ── OpenAI ───────────────────────────────────────────────────────────────────
# Either OPENAI__API_KEY (nested) or the flat OPENAI_API_KEY is accepted.
OPENAI__API_KEY=sk-placeholder
OPENAI__MODEL=gpt-4o
OPENAI__FAST_MODEL=gpt-4o-mini
OPENAI__QUIZ_TEMPERATURE=0.9

# ── mooKIT ────────────────────────────────────────────────────────────────────
# The frontend forwards course/token/uid per request; these are relayed, never persisted.
# Course is appended to the path per request: {BASE_URL}/{course}/{endpoint}
MOOKIT__BASE_URL=https://test.mookit.in/v2/api

# ── Memory (Dev B two-channel transcript) ──────────────────────────────────────
MEMORY__TRANSCRIPT_MAX_TOKENS=6000
MEMORY__TRANSCRIPT_KEEP_RECENT=8

# ── Security ──────────────────────────────────────────────────────────────────
# MUST be changed in production (min 32 printable characters)
SECURITY__SECRET_KEY=dev-secret-key-CHANGE-IN-PRODUCTION-32c
# Trust boundary: if set, callers must send a matching X-Service-Key header (health/ui/docs exempt).
# Leave blank to disable (dev). In production set this to a strong shared secret known only to the
# mooKIT frontend.
SECURITY__SERVICE_API_KEY=
# CORS allow-list (JSON array). Lock to the mooKIT frontend origins in production.
SECURITY__ALLOWED_ORIGINS=["*"]
# Shared secret between the mooKIT frontend and this service. If set, every non-health request must
# send header `x-service-key: <this value>`. Leave blank to disable (dev only).
SECURITY__SERVICE_API_KEY=
# CORS allowlist (JSON array). Lock to the mooKIT frontend origins in production.
SECURITY__ALLOWED_ORIGINS=["*"]

# ── Quiz pipeline feature flags ───────────────────────────────────────────────
# Blueprint-first path: comprehend → plan → multi-span generate.
# QUIZ_BLUEPRINT_ENABLED=true
# Vision comprehension (requires blueprint): read PDF page images for equations/figures.
# QUIZ_VISION_ENABLED=true

# ── Limits ────────────────────────────────────────────────────────────────────
# Upload size cap (bytes). Default 500 MB. Set higher if needed (e.g. 2147483648 for 2 GB).
LIMITS__MAX_FILE_SIZE_BYTES=524288000
LIMITS__RATE_LIMIT_RPM=60
LIMITS__UPLOAD_DIR=/tmp/mookit_uploads

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
# RAG backend: pgvector (OpenAI embeddings in Postgres) | keyword (Redis term-overlap fallback)
RAG_BACKEND=pgvector
# Create tables on startup (dev). Set false in production and run `alembic upgrade head`.
AUTO_CREATE_TABLES=true

# ── Observability (optional — leave blank to disable) ─────────────────────────
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_ENV=development
# OTEL_EXPORTER_OTLP_ENDPOINT=

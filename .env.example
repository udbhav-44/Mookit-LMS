# ── Database ──────────────────────────────────────────────────────────────────
DB__URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mookit_lms
DB__POOL_SIZE=20
DB__MAX_OVERFLOW=10

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS__URL=redis://localhost:6379/0

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI__API_KEY=sk-placeholder
OPENAI__MODEL=gpt-4o

# ── mooKIT ────────────────────────────────────────────────────────────────────
MOOKIT__BASE_URL=https://test.mookit.in/api

# ── Security ──────────────────────────────────────────────────────────────────
# MUST be changed in production (min 32 printable characters)
SECURITY__SECRET_KEY=dev-secret-key-CHANGE-IN-PRODUCTION-32c

# ── Limits ────────────────────────────────────────────────────────────────────
LIMITS__MAX_FILE_SIZE_BYTES=10485760
LIMITS__RATE_LIMIT_RPM=60
LIMITS__UPLOAD_DIR=/tmp/mookit_uploads

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false

# ── Observability (optional — leave blank to disable) ─────────────────────────
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
# OTEL_EXPORTER_OTLP_ENDPOINT=
